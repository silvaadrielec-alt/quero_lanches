<p style="color: green"><%= notice %></p>

<%= render @funcionario %>

<div style="margin-top: 20px;">
  <%= link_to "Editar este funcionário", edit_funcionario_path(@funcionario), style: "color: #D71920; text-decoration: none; margin-right: 15px;" %> |
  <%= link_to "Voltar aos funcionários", funcionarios_path, style: "color: #666; text-decoration: none; margin-left: 15px;" %>

  <div style="margin-top: 30px;">
    <%= button_to "Excluir este funcionário", @funcionario, method: :delete, data: { confirm: "Tem certeza?" }, style: "background: #ff4444; color: white; border: none; padding: 10px 20px; border-radius: 10px; cursor: pointer;" %>
  </div>
</div>
