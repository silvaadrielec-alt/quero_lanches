<div class="card-principal" style="max-width: 600px; margin: 40px auto; text-align: center;">
  <h1 style="color: #D71920;">Equipe Quero Lanches</h1>

  <div id="funcionarios" style="margin-bottom: 20px;">
    <% @funcionarios.each do |funcionario| %>
      <div style="padding: 10px; border-bottom: 1px dashed #ccc;">
        <strong>Nome:</strong> <%= funcionario.nome %> |
        <%= link_to "Perfil", funcionario, style: "color: #D71920;" %>
      </div>
    <% end %>
  </div>

  <%= link_to "Cadastrar Funcionário", new_funcionario_path, class: "btn-anotar", style: "text-decoration: none; display: inline-block;" %>
</div>
