<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh; background-color: #fdf8f5; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
  <div style="background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 100%; max-width: 400px; border-top: 6px solid #D71920; text-align: center;">
    
    <div style="margin-bottom: 30px;">
      <h2 style="color: #D71920; margin-bottom: 10px; font-weight: bold; letter-spacing: 1px;">ÁREA DE ACESSO</h2>
      <p style="color: #666; font-size: 0.95em;">Bem-vindo(a) à Cantina Quero Lanches</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div style="margin-bottom: 20px; text-align: left;">
        <%= f.label :email, "E-mail Profissional", style: "display: block; font-weight: bold; margin-bottom: 8px; color: #444;" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "seu@email.com", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 10px; outline-color: #D71920;" %>
      </div>

      <div style="margin-bottom: 20px; text-align: left;">
        <%= f.label :password, "Senha de Acesso", style: "display: block; font-weight: bold; margin-bottom: 8px; color: #444;" %>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "Digite sua senha", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 10px; outline-color: #D71920;" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div style="margin-bottom: 25px; text-align: left; display: flex; align-items: center;">
          <%= f.check_box :remember_me, style: "width: 18px; height: 18px; margin-right: 10px; cursor: pointer;" %>
          <%= f.label :remember_me, "Manter-me conectado", style: "font-size: 0.9em; color: #666; cursor: pointer;" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "ENTRAR NO SISTEMA", style: "width: 100%; background-color: #D71920; color: white; padding: 14px; border: none; border-radius: 10px; font-weight: bold; cursor: pointer; transition: background 0.3s; font-size: 1em;" %>
      </div>
    <% end %>

    <div style="margin-top: 25px; border-top: 1px solid #eee; padding-top: 15px;">
      <%# Aqui traduzimos os links de 'shared/links' indiretamente mudando o arquivo dele também %>
      <%= render "funcionarios/shared/links" %>
    </div>
  </div>
</div>
