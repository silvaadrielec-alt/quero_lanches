<%# 1. Definimos a URL correta para evitar o erro de rota PATCH %>
<% url_destino = @funcionario.persisted? ? funcionario_path(@funcionario) : funcionarios_path %>

<%= form_with(model: @funcionario, url: url_destino, local: true) do |f| %>
  
  <% if @funcionario.errors.any? %>
    <div style="color: red; background: #fee; padding: 10px; border-radius: 5px; margin-bottom: 20px;">
      <h2 style="font-size: 16px;"><%= pluralize(@funcionario.errors.count, "erro") %> impediram o salvamento:</h2>
      <ul>
        <% @funcionario.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div style="margin-bottom: 15px;">
    <%= f.label :nome, "Nome Completo", style: "display: block; font-weight: bold; color: #D71920;" %>
    <%= f.text_field :nome, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 5px;" %>
  </div>

  <div style="margin-bottom: 15px;">
    <%= f.label :email, "E-mail de Acesso", style: "display: block; font-weight: bold; color: #D71920;" %>
    <%= f.email_field :email, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 5px;" %>
  </div>

  <div style="margin-bottom: 15px;">
    <%= f.label :password, "Senha Provisória", style: "display: block; font-weight: bold; color: #D71920;" %>
    <%= f.password_field :password, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 5px;", placeholder: @funcionario.persisted? ? "Deixe em branco para não alterar" : "" %>
  </div>

  <div style="margin-bottom: 15px;">
    <%= f.label :password_confirmation, "Confirme a Senha", style: "display: block; font-weight: bold; color: #D71920;" %>
    <%= f.password_field :password_confirmation, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 5px;" %>
  </div>

  <div style="margin-bottom: 20px; padding: 10px; border: 1px dashed #D71920; border-radius: 8px; background-color: #fff;">
    <%= f.label :admin, "Acesso de Administrador?", style: "display: block; font-weight: bold; color: #D71920; margin-bottom: 5px;" %>
    <div style="display: flex; align-items: center; gap: 10px;">
      <%= f.check_box :admin, style: "width: 20px; height: 20px;" %>
      <span style="color: #666; font-size: 14px;">(Permite visualizar faturamentos e gerenciar equipe)</span>
    </div>
  </div>

  <div style="margin-top: 30px;">
    <%= f.submit "SALVAR ALTERAÇÕES", class: "btn-quero", style: "width: 100%;" %>
  </div>

<% end %>
