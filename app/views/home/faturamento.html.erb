<div style="margin-bottom: 30px; display: flex; justify-content: center; gap: 8px; flex-wrap: wrap;" class="no-print">
  <%= link_to "DIÁRIO", faturamento_path(periodo: 'diario'), class: "btn-filtro" %>
  <%= link_to "SEMANAL", faturamento_path(periodo: 'semanal'), class: "btn-filtro" %>
  <%= link_to "MENSAL", faturamento_path(periodo: 'mensal'), class: "btn-filtro" %>
  <%= link_to "TRIMESTRAL", faturamento_path(periodo: 'trimestral'), class: "btn-filtro" %>
  <%= link_to "SEMESTRAL", faturamento_path(periodo: 'semestral'), class: "btn-filtro" %>
  <%= link_to "ANUAL", faturamento_path(periodo: 'anual'), class: "btn-filtro" %>
<a href="javascript:void(0)" 
   onclick="setTimeout(function(){ window.print(); }, 500);" 
   data-turbo="false"
   class="no-print" 
   style="background: #333; color: white; padding: 10px 25px; border-radius: 8px; font-weight: bold; text-decoration: none; margin-left: 10px; display: inline-block; cursor: pointer; border: 2px solid #555;">
   🖨️ GERAR PDF / IMPRIMIR
</a>
</div>

<div style="text-align: center; margin-top: 30px; font-family: sans-serif;">
  <h1 style="color: #D71920;">Resumo de Faturamento - Hoje</h1>

   <div style="display: flex; gap: 20px; justify-content: center; margin-top: 40px; flex-wrap: wrap;">
    <div style="background: white; border-radius: 15px; padding: 25px; width: 280px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); border-top: 8px solid #2196f3;">
      <span style="color: #666; font-weight: bold;">TOTAL VENDIDO</span>
      <h2 style="color: #0d47a1; font-size: 2.2em; margin: 15px 0;"><%= number_to_currency(@total_faturado) %></h2>
      <p style="color: #666;"><%= @vendas_hoje.count %> pedidos realizados</p>
    </div>

    <div style="background: white; border-radius: 15px; padding: 25px; width: 280px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); border-top: 8px solid #4caf50;">
      <span style="color: #666; font-weight: bold;">LUCRO ESTIMADO</span>
      <h2 style="color: #1b5e20; font-size: 2.2em; margin: 15px 0;"><%= number_to_currency(@lucro_estimado) %></h2>
      <% margem = (@total_faturado > 0) ? ((@lucro_estimado / @total_faturado) * 100).round(1) : 0 %>
      <p style="color: #4caf50; font-weight: bold;">Margem de <%= margem %>%</p>
    </div>
  </div>

  <div style="background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); margin: 30px auto; max-width: 1000px;" class="no-print">
  <h3 style="color: #D71920; margin-bottom: 20px; text-align: center;">📈 Evolução das Vendas</h3>
  
  <% if @vendas_por_dia.any? %>
    <%= line_chart @vendas_por_dia, prefix: "R$ ", download: {filename: "grafico_vendas"}, library: { backgroundColor: "#ffffff" } %>
  <% else %>
    <p style="text-align: center; color: #999; padding: 20px;">Sem dados de vendas para exibir o gráfico neste período.</p>
  <% end %>
</div>

<div style="max-width: 600px; margin: 40px auto; background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);" class="no-print">
  <h3 style="color: #D71920; border-bottom: 2px solid #f2f2f2; padding-bottom: 10px;">🏆 Itens Mais Vendidos (<%= params[:periodo]&.capitalize || "Hoje" %>)</h3>
  <table style="width: 100%; border-collapse: collapse; margin-top: 10px;">
    <% if @mais_vendidos.any? %>
      <% @mais_vendidos.each do |item| %>
        <tr style="border-bottom: 1px solid #eee;">
          <%# O &.nome evita erro se o produto tiver sido deletado do banco %>
          <td style="padding: 10px; text-align: left; font-weight: bold;"><%= item.produto&.nome || "Produto não encontrado" %></td>
          <td style="padding: 10px; text-align: right; color: #666;"><%= item.total_qtd.to_i %> vendidos</td>
        </tr>
      <% end %>
    <% else %>
      <tr>
        <td colspan="2" style="padding: 20px; color: #999; text-align: center;">Nenhuma venda registrada neste período.</td>
      </tr>
    <% end %>
  </table>
</div>

  <div style="margin-top: 50px;">
    <%= link_to "VOLTAR AO PAINEL", root_path, style: "text-decoration: none; padding: 12px 25px; background: #666; color: white; border-radius: 10px; font-weight: bold;" %>
  </div>
</div>

<style>
  .btn-filtro { text-decoration: none; background: #f2f2f2; color: #333; padding: 8px 15px; border-radius: 8px; font-weight: bold; transition: 0.3s; }
  .btn-filtro:hover { background: #D71920; color: white; }

 @media print {
    /* Esconde o menu de botões e navegação no PDF */
    .no-print, nav, .navbar, .navbar-quero, .btn-filtro { 
      display: none !important; 
    }
    
    /* FORÇA AS CORES, FUNDOS E O GRÁFICO EM TUDO */
    * { 
      -webkit-print-color-adjust: exact !important; 
      print-color-adjust: exact !important; 
      color-adjust: exact !important;
    }

    body { 
      background-color: white !important;
    }

    /* Garante que o gráfico (SVG ou Canvas) seja tratado como prioridade */
    canvas, svg {
    display: block !important;
    position: relative !important;
    width: 100% !important;
  }
  
  /* ADICIONE ESTE BLOCO AQUI: */
 .chart-container, div[id^="chart-"], .chartkick-chart {
   display: block !important;
  visibility: visible !important;
   opacity: 1 !important;
   page-break-inside: avoid !important;
  }
  }
  }
</style>