<div class="card-principal" style="max-width: 1100px; margin: 40px auto; text-align: center;">
  <h1 style="color: var(--vermelho-quero); margin-bottom: 30px;">Cardápio de Vendas</h1>

  <%# BARRA DE PESQUISA QUE VOCÊ SUGERIU %>
  <div style="margin-bottom: 20px;">
    <input type="text" id="buscaCardapio" onkeyup="filtrarCardapio()" placeholder="🔍 Pesquisar lanche..." 
           style="width: 80%; padding: 12px; border-radius: 20px; border: 1px solid #007bff; outline: none;">
  </div>

<% if current_funcionario.admin? %>
  <div style="margin-top: -10px; margin-bottom: 30px;">
    <%= link_to "Cadastrar Novo Item no Cardápio", new_cardapio_path, 
        style: "background-color: #D71920; color: white; padding: 12px 25px; border-radius: 25px; text-decoration: none; font-weight: bold; display: inline-block; box-shadow: 0 4px 6px rgba(0,0,0,0.1);" %>
  </div>
<% end %>

  <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 10px; overflow: hidden;">
    <thead>
      <tr style="background: #D71920; color: white;">
        <th style="padding: 15px; text-align: left; padding-left: 30px;">LANCHE / BEBIDA</th>
        <th style="padding: 15px; text-align: center;">PREÇO</th>
        <th style="padding: 15px; text-align: center;">AÇÕES</th>
      </tr>
    </thead>
    <tbody>
      <% @produtos.each do |produto| %>
        <tr style="border-bottom: 1px solid #eee;">
          <td style="padding: 15px; text-align: left; padding-left: 30px;">
            <strong><%= produto.nome %></strong>
          </td>
          <td style="padding: 15px; text-align: center; font-weight: bold;">
            <%= number_to_currency(produto.preco_venda) %>
          <td style="text-align: center;">
  <%# Link 'Detalhes' - Visível para todos os funcionários %>
  <%= link_to 'Detalhes', cardapio_path(produto), 
      style: "color: #0000FF; text-decoration: underline; margin-right: 15px; font-family: sans-serif;" %>

  <%# Links de Gestão - Visíveis APENAS para Admin %>
  <% if current_funcionario.admin? %>
    <%= link_to 'Editar', edit_cardapio_path(produto), 
        style: "color: #0000FF; text-decoration: underline; margin-right: 15px; font-family: sans-serif;" %>

    <%= link_to 'Excluir', cardapio_path(produto), method: :delete, 
        data: { confirm: 'Tem certeza que deseja excluir este item do cardápio?' },
        style: "color: #D71920; text-decoration: underline; font-family: sans-serif;" %>
  <% end %>
    </td>
    </tr>
  <% end %>
    </tbody>
  </table>

  <% if current_funcionario.admin? %>
  <%= link_to 'NOVO ITEM NO CARDÁPIO', new_cardapio_path, class: 'btn-novo' %>
<% end %>
</div>

<script>
function filtrarCardapio() {
  var input = document.getElementById("buscaCardapio").value.toUpperCase();
  var rows = document.querySelector("table tbody").rows;
  for (var i = 0; i < rows.length; i++) {
    var nome = rows[i].cells[0].textContent.toUpperCase();
    rows[i].style.display = nome.includes(input) ? "" : "none";
  }
}
</script>