<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh; background-color: #fdf8f5;">
  <div style="background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 100%; max-width: 400px; border-top: 6px solid #D71920; text-align: center;">
    
    <div style="margin-bottom: 20px;">
      <%= image_tag "logo.png", style: "width: 80px; border-radius: 50%;" if Rails.application.assets.find_asset('logo.png') %>
      <h2 style="color: #D71920; margin-top: 10px; font-weight: bold;">Área de Acesso</h2>
      <p style="color: #666; font-size: 0.9em;">Identifique-se para continuar</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div style="margin-bottom: 20px; text-align: left;">
        <%= f.label :email, "E-mail cadastrado", style: "display: block; font-weight: bold; margin-bottom: 5px; color: #555;" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "exemplo@email.com", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 10px; box-sizing: border-box;" %>
      </div>

      <div style="margin-bottom: 20px; text-align: left;">
        <%= f.label :password, "Sua senha", style: "display: block; font-weight: bold; margin-bottom: 5px; color: #555;" %>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", style: "width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 10px; box-sizing: border-box;" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div style="margin-bottom: 20px; text-align: left; display: flex; align-items: center;">
          <%= f.check_box :remember_me, style: "margin-right: 10px;" %>
          <%= f.label :remember_me, "Lembrar de mim", style: "font-size: 0.9em; color: #666;" %>
        </div>
      <% end %>

      <div style="margin-top: 30px;">
        <%= f.submit "ENTRAR NO SISTEMA", style: "width: 100%; background-color: #D71920; color: white; padding: 14px; border: none; border-radius: 10px; font-weight: bold; cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px rgba(215, 25, 32, 0.2);" %>
      </div>
    <% end %>

    <div style="margin-top: 20px; font-size: 0.85em;">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
