<p style="color: green"><%= notice %></p>

<%= render @cliente %>

<div style="margin-top: 20px;">
  <%= link_to "Editar este cliente", edit_cliente_path(@cliente), style: "color: #D71920; text-decoration: none; margin-right: 15px;" %> |
  <%= link_to "Voltar aos clientes", clientes_path, style: "color: #666; text-decoration: none; margin-left: 15px;" %>

  <div style="margin-top: 30px;">
    <%= button_to "Excluir este cliente", @cliente, method: :delete, data: { confirm: "Tem certeza?" }, style: "background: #ff4444; color: white; border: none; padding: 10px 20px; border-radius: 10px; cursor: pointer;" %>
  </div>
</div>