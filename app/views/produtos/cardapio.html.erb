<h1>Cardápio de Vendas</h1>
<table class="table">
  <thead>
    <tr>
      <th>Lanche/Bebida</th>
      <th>Preço</th>
    </tr>
  </thead>
  <tbody>
    <% @produtos.each do |produto| %>
      <tr>
        <td><%= produto.nome %></td>
        <td><%= number_to_currency(produto.preco_venda) %></td>
      </tr>
    <% end %>
  </tbody>
</table>