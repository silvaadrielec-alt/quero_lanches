<p style="color: green"><%= notice %></p>

<div class="container-estoque" style="max-width: 900px; margin: 0 auto; padding: 20px;">
  <%= render @produto %>

  <div style="margin-top: 20px;">
    <% if current_funcionario.admin? %>
      <%= link_to 'Editar este produto', edit_produto_path(@produto), style: 'color: #0000EE; text-decoration: underline; font-size: 1.1em; margin-right: 15px;' %>
    <% end %>
    
    <div style="margin-bottom: 20px;">
      <%# AGORA FIXO: Sempre volta para o estoque geral %>
      <%= link_to "← VOLTAR AO ESTOQUE", produtos_path, style: "color: #007bff; text-decoration: none; font-weight: bold; font-size: 1.1em;" %>
    </div>
    
    <% if current_funcionario.admin? %>
      <div style="margin-top: 30px;">
        <%= button_to "Excluir este produto", @produto, method: :delete, data: { confirm: "Tem certeza?" }, style: "background: #ff4444; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer;" %>
      </div>

      <%# Blocos de Preço, Custo e Lucro %>
      <div style="display: flex; gap: 20px; margin: 25px 0; flex-wrap: wrap; clear: both;">
        <div style="flex: 1; min-width: 200px; background: #e3f2fd; padding: 15px; border-radius: 12px; border-left: 6px solid #2196f3;">
          <span style="color: #666; font-size: 0.85em; font-weight: bold; text-transform: uppercase;">Preço de Venda</span>
          <h3 style="margin: 5px 0; color: #0d47a1; font-size: 1.6em;"><%= number_to_currency(@produto.valor_unitario) %></h3>
        </div>

        <div style="flex: 1; min-width: 200px; background: #fff3e0; padding: 15px; border-radius: 12px; border-left: 6px solid #ff9800;">
          <span style="color: #666; font-size: 0.85em; font-weight: bold; text-transform: uppercase;">Custo de Produção</span>
          <h3 style="margin: 5px 0; color: #e65100; font-size: 1.6em;">
            <% custo_total = @produto.composicoes.sum { |c| c.quantidade * (c.insumo.valor_unitario || 0) } %>
            <%= number_to_currency(custo_total) %>
          </h3>
        </div>

        <div style="flex: 1; min-width: 200px; background: #e8f5e9; padding: 15px; border-radius: 12px; border-left: 6px solid #4caf50;">
          <span style="color: #666; font-size: 0.85em; font-weight: bold; text-transform: uppercase;">Lucro Bruto</span>
          <h3 style="margin: 5px 0; color: #1b5e20; font-size: 1.6em;">
            <%= number_to_currency(@produto.valor_unitario - custo_total) %>
          </h3>
        </div>
      </div>

      <hr style="margin-top: 40px; border: 1px solid #eee;">
      <h3 style="color: #D71920; font-weight: bold;">📋 Ficha Técnica / Receita</h3>
      
      <table class="table" style="width: 100%; margin-top: 20px; border-collapse: collapse;">
        <thead style="background-color: #f8f8f8;">
          <tr>
            <th style="padding: 12px; text-align: left;">Insumo</th>
            <th style="padding: 12px; text-align: left;">Qtd. Gasta</th>
            <th style="padding: 12px; text-align: left;">Medida Uso</th>
            <th style="padding: 12px; text-align: left;">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @produto.composicoes.each do |comp| %>
            <tr>
              <td style="padding: 10px;"><%= comp.insumo.nome %></td>
              <td style="padding: 10px;"><%= comp.quantidade %></td>
              <td style="padding: 10px;"><span style="background: #17a2b8; color: white; padding: 4px 8px; border-radius: 5px;"><%= comp.unidade_medida_uso %></span></td>
              <td style="padding: 10px;">
                <%= button_to 'Remover', composico_path(comp), method: :delete, data: { confirm: 'Deseja remover?' }, style: "background: none; border: none; color: #ff4444; cursor: pointer;" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <%# Formulário para adicionar insumos à receita %>
      <div style="background: #fdf8f5; padding: 20px; border-radius: 12px; margin-top: 20px; border: 1px dashed #D71920;">
        <h4 style="margin-top: 0;">Adicionar Insumo à Receita</h4>
        <%= form_with(model: [ @produto, Composicao.new ], url: produto_composicoes_path(@produto)) do |f| %>
          <div style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
            <div style="flex: 2;">
              <%= f.label :insumo_id, "Insumo" %>
              <%= f.collection_select :insumo_id, Produto.where(categoria: "Insumo"), :id, :nome, { prompt: "Selecione..." }, style: "width: 100%; padding: 8px;" %>
            </div>
            <div style="flex: 1;">
              <%= f.label :quantidade, "Qtd." %>
              <%= f.number_field :quantidade, step: :any, style: "width: 100%; padding: 8px;" %>
            </div>
            <div style="flex: 1;">
              <%= f.label :unidade_medida_uso, "Medida" %>
              <%= f.select :unidade_medida_uso, ['unidade', 'fatia', 'kg', 'gramas', 'ml'], {}, style: "width: 100%; padding: 8px;" %>
            </div>
            <%= f.submit "Salvar", style: "background: #28a745; color: white; padding: 10px 20px; border: none; border-radius: 8px; cursor: pointer;" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
