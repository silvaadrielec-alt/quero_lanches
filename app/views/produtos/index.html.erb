<div class="card-principal" style="max-width: 1100px; margin: 40px auto; text-align: center;">
  
  <h1 style="color: var(--vermelho-quero); margin-bottom: 30px;">Gestão de Estoque Geral</h1>

  <%# --- TABELA DE PRODUTOS PARA VENDA --- %>
  <h2 style="color: #555; text-align: left; margin-left: 20px;">Produtos p/ Venda (Lanches, Sucos, Açaí)</h2>
  <table>
    <thead>
      <tr>
        <th>Produto</th>
        <th>Valor de Custo</th> <%# Coluna 1: O que a cantina paga %>
        <th>Preço de Venda</th> <%# Coluna 2: O que o aluno paga %>
        <th>Matriz</th>
        <th>Pav. Novo</th>
        <th>Pav. Antigo</th>
        <th style="text-align: center;">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @produtos.where(categoria: ["Venda", nil]).each do |produto| %>
        <tr>
          <td style="text-align: left; padding-left: 20px;">
            <strong><%= produto.nome %></strong>
          </td>

          <%# Exibe o Custo (Compra/Produção) %>
          <td>
            <%= number_to_currency(produto.valor_unitario, unit: "R$ ", separator: ",", delimiter: ".") %>
          </td>

          <%# Exibe o Preço de Venda (O valor que estava "sumido" nesta tabela) %>
          <td style="font-weight: bold; color: #28a745;">
            <%= number_to_currency(produto.preco_venda, unit: "R$ ", separator: ",", delimiter: ".") %>
            <br><small style="color: #666; font-weight: normal;">(por <%= produto.unidade_medida %>)</small>
          </td>

          <td><%= produto.estoque_centro.to_i %></td>
          <td><%= produto.estoque_pavilhao_novo.to_i %></td>
          <td style="color: var(--vermelho-quero); font-weight: bold;">
            <%= produto.estoque_pavilhao_antigo.to_i %>
          </td>

          <td style="text-align: center;">
            <%= link_to 'Ver Receita', produto_path(produto), class: 'btn btn-info btn-sm' %>
            <% if current_funcionario.admin? %>
              <%= link_to 'Editar', edit_produto_path(produto), class: 'btn btn-warning btn-sm' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <hr style="margin: 40px 0; border: 0; border-top: 1px solid #eee;">

  <%# --- TABELA DE INSUMOS (O QUE NÃO SAI DIRETO NA VENDA) --- %>
  <h2 style="color: #555; text-align: left; margin-left: 20px;">Insumos e Matérias-primas (Queijo, Carne, Frutas)</h2>
  <table style="border-left: 5px solid #666;">
    <thead style="background-color: #666;"> <%# Cabeçalho cinza para diferenciar %>
      <tr>
        <th>Insumo</th>
        <th>Medida</th>
        <th>Matriz</th>
        <th>Pav. Novo</th>
        <th>Pav. Antigo</th>
        <th style="text-align: center;">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @produtos.where(categoria: "Insumo").each do |insumo| %>
        <tr>
          <td><strong><%= insumo.nome %></strong></td>
          <td><%= insumo.unidade_medida %></td>
          <td><%= insumo.estoque_centro %></td>
          <td><%= insumo.estoque_pavilhao_novo %></td>
          <td><%= insumo.estoque_pavilhao_antigo %></td>
          <td style="text-align: center;">
           <%# Botão visível para todos os funcionários %>
           <%= link_to 'Ver Detalhes', produto_path(insumo), class: 'btn btn-info btn-sm' %>
            <% if current_funcionario.admin? %>            
              <%= link_to 'Editar', edit_produto_path(insumo), class: 'btn btn-warning btn-sm' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if current_funcionario.admin? %>
    <div style="margin-top: 30px;">
      <%= link_to "CADASTRAR NOVO ITEM", new_produto_path, class: "btn-quero" %>
    </div>
  <% end %>
</div>
